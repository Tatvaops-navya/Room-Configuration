# Google Gemini API – used for Preset, AI, and Replace.
# Get your key from https://aistudio.google.com/apikey
# Copy this file to .env and set your real key in .env (never commit .env).

# Same as IMAGE_GENERATION_API_KEY; VITE_ prefix is required for Vite to expose it to the app.
VITE_IMAGE_GENERATION_API_KEY=your_api_key_here

# Model Configuration
VITE_GEMINI_TEXT_MODEL=gemini-2.5-flash
VITE_GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# AI Text mode: with only VITE_IMAGE_GENERATION_API_KEY set, Gemini is used to find objects from text (e.g. "coffee table").
# Optional: Grounding DINO + SAM pipeline (text detection → pixel segmentation).
# When both are set, AI Text uses Grounding DINO for detection instead of Gemini.
# VITE_GROUNDING_DINO_API_KEY=your_key
# VITE_GROUNDING_DINO_API_URL=https://api.replicate.com/v1/predictions  # e.g. lucataco/grounding-dino
# VITE_SEGMENTATION_API_KEY=your_key
# VITE_SEGMENTATION_API_URL=https://api.replicate.com/v1/predictions   # e.g. segment-anything
