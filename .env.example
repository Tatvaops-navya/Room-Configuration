# Copy to .env.local for local dev, or add these in Vercel Project Settings → Environment Variables

# Required: Google Gemini API key (for image analysis and prompt enhancement)
IMAGE_GENERATION_API_KEY=your_gemini_api_key_here

# Optional: override Gemini models
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# 360°-style room tour video (/api/room-tour-video) — Runway Gen-4 Turbo (image-to-video). Requires RUNWAYML_API_SECRET and Supabase bucket below.
RUNWAYML_API_SECRET=your_runway_api_secret_here
# Bucket for temporary first-frame JPEGs (service role uploads; signed URLs for Runway to fetch). Create in Supabase Dashboard → Storage.
ROOM_TOUR_STORAGE_BUCKET=room-tour-temp
# Optional Runway tunables (Gen-4 Turbo; model is gen4_turbo in code). Default duration is 10s; set to 5 for shorter/cheaper runs.
# RUNWAY_VIDEO_DURATION=10
# RUNWAY_VIDEO_RATIO=1280:720
# RUNWAY_VIDEO_SEED=

# Room editor inpaint (/api/add, /api/edit, …): max wait for Gemini (ms). Default 300000 (5 min). Range 60000–600000.
# GEMINI_IMAGE_TIMEOUT_MS=300000

# Optional: for actual image generation (otherwise placeholder images are used)
# STABILITY_AI_API_KEY=your_stability_key_here
# REPLICATE_API_TOKEN=your_replicate_token_here

# Lift Subject / SAM (Segment Anything) - for click selection
SEGMENTATION_API_KEY=
SEGMENTATION_API_URL=

# Grounding DINO - for hover/auto object detection
GROUNDING_DINO_API_KEY=
GROUNDING_DINO_API_URL=

# Supabase (product variations, floor/wall tiles from mytyles_vitrified_tiles, etc.)
NEXT_PUBLIC_SUPABASE_URL=https://uxqmrmxodsychttcjitp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Public URL while developing (optional): run `npm run dev` then in another terminal `npm run tunnel`
# One-time: ngrok config add-authtoken <token from https://dashboard.ngrok.com/get-started/your-authtoken >
